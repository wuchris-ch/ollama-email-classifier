# Local Ollama endpoint (default port 11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Optional: run the classifier on a remote API instead of local Ollama.
# Any LiteLLM model string works; the provider's key must also be set
# (e.g. DEEPSEEK_API_KEY for deepseek/, OPENAI_API_KEY for openai/).
# CLASSIFIER_LM=deepseek/deepseek-v4-pro
# DEEPSEEK_API_KEY=

# Parallel LM calls during eval/optimize (default 8).
# EVAL_WORKERS=8

# Judge model (paid API). Required for optimize.py and for eval.py unless
# you pass --no-judge.
OPENAI_API_KEY=
JUDGE_MODEL=gpt-4o-mini

# Set to 1 to enable the live integration tests in
# tests/test_integration_ollama.py (needs a reachable Ollama instance).
# RUN_OLLAMA_TESTS=1
